# ─── Firebase ─────────────────────────────────────────────────────────────────
# Obtenha esses valores em: https://console.firebase.google.com
# Projeto → Configurações → Geral → Seus apps → SDK snippet (Configuração)

VITE_FIREBASE_API_KEY=AIzaSy_SUBSTITUA_PELA_SUA_CHAVE
VITE_FIREBASE_AUTH_DOMAIN=SEU-PROJETO.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=SEU-PROJETO-ID
VITE_FIREBASE_STORAGE_BUCKET=SEU-PROJETO.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ─── EmailJS (envio de planos por e-mail) ─────────────────────────────────────
# Obtenha em: https://www.emailjs.com → Email Services / Email Templates / Account
# Sem essas 3 variáveis, a tela "Envio de Planos" mostra um aviso de configuração
# e não dispara e-mails. Com elas, o envio é real.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
#
# Variáveis esperadas pelo template do EmailJS:
#   {{to_email}} {{to_name}} {{from_name}} {{diet_date}} {{portal_url}} {{message}}

# NOTA: Copie este arquivo para .env.local e substitua pelos valores reais.
# NUNCA commite o arquivo .env.local — ele já está no .gitignore.
